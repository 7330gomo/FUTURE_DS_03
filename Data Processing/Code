----------------------------------------CODE

    WITH ranked_activity AS (

    SELECT
        UserID,
        timestamp,
        MONTHNAME(timestamp) AS month,
        DAYNAME(timestamp) AS day,
        HOUR(timestamp) AS hour,
        YEAR(timestamp) AS year,
        PageType,
        ReferralSource,

        ROW_NUMBER() OVER(
            PARTITION BY UserID
            ORDER BY timestamp DESC
        ) AS rn

    FROM customers.conversion.data
)

SELECT

    month,
    day,
    hour,
    year,
    ReferralSource,

    -- Total visitors (all users)
    COUNT(DISTINCT UserID) AS total_visitors,

    -- Leads
    COUNT(DISTINCT CASE 
        WHEN PageType IN ('cart','checkout')
        THEN UserID
    END) AS number_of_leads,

    -- Converted customers
    COUNT(DISTINCT CASE 
        WHEN PageType = 'confirmation'
        THEN UserID
    END) AS number_of_converted_customers,

    -- Traffic to Lead Conversion Rate
    COALESCE(
        TRY_DIVIDE(

            COUNT(DISTINCT CASE 
                WHEN PageType IN ('cart','checkout')
                THEN UserID
            END),

            COUNT(DISTINCT UserID)

        ),
    0) AS traffic_to_lead_conversion_rate,

    -- Lead to Customer Conversion Rate
    COALESCE(
        TRY_DIVIDE(

            COUNT(DISTINCT CASE 
                WHEN PageType = 'confirmation'
                THEN UserID
            END),

            COUNT(DISTINCT CASE 
                WHEN PageType IN ('cart','checkout')
                THEN UserID
            END)

        ),
    0) AS lead_to_customer_conversion_rate,

    -- Lead Drop-off Rate
    COALESCE(
        TRY_DIVIDE(

            COUNT(DISTINCT CASE 
                WHEN PageType IN ('cart','checkout')
                THEN UserID
            END)

            -

            COUNT(DISTINCT CASE 
                WHEN PageType = 'confirmation'
                THEN UserID
            END),

            COUNT(DISTINCT CASE 
                WHEN PageType IN ('cart','checkout')
                THEN UserID
            END)

        ),
    0) AS lead_dropoff_rate,

    -- Visitor Drop-off Rate
    COALESCE(
        TRY_DIVIDE(

            COUNT(DISTINCT UserID)

            -

            COUNT(DISTINCT CASE 
                WHEN PageType IN ('cart','checkout')
                THEN UserID
            END),

            COUNT(DISTINCT UserID)

        ),
    0) AS visitor_dropoff_rate

FROM ranked_activity

WHERE rn = 1

GROUP BY
    month,
    day,
    hour,
    year,
    ReferralSource;






